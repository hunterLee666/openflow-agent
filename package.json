{
  "name": "ai-coding-agent",
  "version": "0.1.0",
  "module": "backend/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run backend/main.tsx",
    "dev": "bun run --watch backend/main.tsx",
    "server": "bun run backend/main.tsx",
    "server:dev": "bun run --watch backend/main.tsx",
    "client": "bun run frontend/tui/client-app.tsx",
    "client:dev": "bun run --watch frontend/tui/client-app.tsx",
    "all": "bun run scripts/start-all.ts",
    "all:dev": "bun run --watch scripts/start-all.ts",
    "build": "bun build backend/main.tsx --outdir ./dist --target bun",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:run": "bun test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@slack/bolt": "^4.7.1",
    "baileys": "^7.0.0-rc.9",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ink": "^5.2.0",
    "node-telegram-bot-api": "^0.67.0",
    "openai": "^5.3.0",
    "react": "^18.3.1",
    "react-devtools-core": "^7.0.1",
    "sqlite-vec": "^0.1.9",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.18",
    "typescript": "^5.8.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
