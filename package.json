{
  "name": "ai-coding-agent",
  "version": "0.1.0",
  "module": "backend/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run backend/main.tsx",
    "tui": "bun run frontend/index.tsx",
    "dev": "bun run --watch backend/main.tsx",
    "server": "bun run backend/main.tsx",
    "server:dev": "bun run --watch backend/main.tsx",
    "all": "bun run scripts/start-all.ts",
    "all:dev": "bun run --watch scripts/start-all.ts",
    "build": "bun build backend/main.tsx --outdir ./dist --target bun",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:all": "bun test tests/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@ink-tools/ink-mouse": "^2.1.0",
    "@slack/bolt": "^4.7.1",
    "baileys": "^7.0.0-rc.9",
    "chalk": "^5.4.1",
    "class-variance-authority": "^0.7.1",
    "cli-spinners": "^3.4.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "commander": "^13.1.0",
    "ink": "^7.0.1",
    "node-telegram-bot-api": "^0.67.0",
    "openai": "^5.3.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-devtools-core": "^7.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.18",
    "typescript": "^5.8.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
